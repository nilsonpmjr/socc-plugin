# Port the Hono server listens on.
PORT=8787

# JWT verification key shared with the Vantage backend.
# Vantage mints scope=socc tokens; the plugin validates them here.
SOCC_JWT_SECRET=change-me-to-a-32-byte-hex-string

# 32-byte hex master key for libsodium crypto_secretbox_easy.
# Encrypts provider credentials (API keys) at rest in MongoDB.
SOCC_CREDENTIALS_MASTER_KEY=change-me-to-a-32-byte-hex-string

# MongoDB connection string. The plugin stores session metadata and
# encrypted per-user credentials in this database.
MONGO_URI=mongodb://localhost:27017/socc_plugin

# Session TTL in milliseconds. Idle workers past this are terminated.
SESSION_TTL_MS=900000

# Maximum concurrent workers (sessions) this instance will host.
MAX_CONCURRENT_SESSIONS=50
