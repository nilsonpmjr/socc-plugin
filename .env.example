# Port the Hono server listens on.
PORT=7070

# JWT verification key shared with the Vantage backend.
# Vantage mints scope=socc tokens; the plugin validates them here.
# MUST be 64 hex chars (32 bytes). Generate with: openssl rand -hex 32
SOCC_INTERNAL_SECRET=change-me-to-a-64-char-hex-string

# 32-byte hex master key for libsodium crypto_secretbox_easy.
# Encrypts provider credentials (API keys) at rest in MongoDB.
# MUST be exactly 64 hex chars. Generate with: openssl rand -hex 32
SOCC_MASTER_KEY=change-me-to-a-64-char-hex-string

# MongoDB connection string. The plugin stores session metadata and
# encrypted per-user credentials in this database.
#   - Standalone (local Mongo on host):  mongodb://localhost:27017
#   - docker compose (sibling service):  mongodb://socc-mongo:27017
MONGO_URI=mongodb://localhost:27017
MONGO_DB=socc_plugin

# Session TTL in milliseconds. Idle workers past this are terminated.
SESSION_TTL_MS=900000

# Maximum concurrent workers (sessions) this instance will host.
MAX_CONCURRENT_SESSIONS=50

# When false (default), creating an `ollama` provider credential is
# rejected with error `local_provider_disabled`. Admins flip to true to
# allow local-hosted LLMs.
SOCC_ALLOW_LOCAL_PROVIDERS=false

# ── v1.0.1 / Fase 3.1: OpenAI Codex OAuth handshake ──────────────────

# Optional. Enables /v1/oauth/openai-codex/login to generate a PKCE
# login redirect. Token exchange is intentionally still gated until a
# stable provider contract/client is configured.
# OPENAI_CODEX_OAUTH_CLIENT_ID=
# OPENAI_CODEX_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/api/socc/oauth/openai-codex/callback
# OPENAI_CODEX_OAUTH_AUTHORIZE_URL=https://auth.openai.com/oauth/authorize

# ── v1.1 (Fase 5) ─────────────────────────────────────────────────────

# Vantage backend URL for the tool gateway (query_feed, analyze_ioc,
# search_watchlist, search_incidents, get_system_health). When absent,
# tools resolve as deny — chat still works fine without it.
# VANTAGE_API_URL=http://backend:8000/api

# Conversation history TTL in days (PRD §LGPD default: 30 days).
# Set to 0 to disable persistence entirely.
MESSAGE_TTL_DAYS=30
